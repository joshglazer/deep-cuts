    "next": "16.2.10",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.7.0"
  },
  "devDependencies": {
    "@astryxdesign/cli": "^0.1.4",
    "@aws-amplify/backend": "^1.23.0",
