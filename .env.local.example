# Spotify app credentials — create an app at https://developer.spotify.com/dashboard
# Redirect URI to register there: http://127.0.0.1:3000/api/auth/callback/spotify
# (Spotify only allows http:// for the loopback IP literal 127.0.0.1, not the
# "localhost" hostname — use 127.0.0.1 everywhere below too.)
AUTH_SPOTIFY_ID=
AUTH_SPOTIFY_SECRET=

# Auth.js session encryption secret — generate with: npx auth secret
AUTH_SECRET=

# Without this, Auth.js derives the origin per-request from headers, and
# different internal code paths (the signIn() server action vs. the
# /api/auth/[...nextauth] route handler) can derive it inconsistently —
# causing Spotify to reject the token exchange with
# "invalid_grant: Invalid redirect URI" even though sign-in itself works.
# Must match a redirect URI registered on the Spotify app above exactly.
AUTH_URL=http://127.0.0.1:3000

# Optional: adds a "Preview sign-in" button that creates a fake session
# without going through Spotify OAuth, so you can view signed-in pages
# without a Spotify app configured. No real access token comes with it, so
# Spotify-backed features (album search) stay non-functional. Same flag PR
# previews use — see README's "Preview environments" section.
# ENABLE_PREVIEW_LOGIN=true
